# Copier ce fichier en .env et remplir avec tes vraies clés
# Ne jamais committer le .env réel sur GitHub

# AWS S3
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCES_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-west-3

# Bucket S3
S3_BUCKET=world-cup-2026-prediction

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cdm2026_predictions
